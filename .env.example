# ============================================================================
# RIM Admin Backend — Environment Variables
# ----------------------------------------------------------------------------
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
# Required vars are marked [REQ]. Vars with defaults are [OPT].
# CSDP additions are grouped at the bottom.
# ============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
# [REQ] development | production | test | staging
NODE_ENV=development
# [OPT] hot-path Nest API port (NGINX upstream points here)
PORT=3000
# [OPT] global URL prefix (default 'api' → /api/...)
API_PREFIX=api
# [OPT] CORS allowlist, comma-separated; if empty, sensible localhost defaults are used
ALLOWED_ORIGINS=https://rim-admin-frontend.onrender.com,https://rim-admin.vercel.app,http://localhost:5173
# [OPT] frontend origin (used for OAuth redirects, password-reset links, etc.)
FRONTEND_URL=http://localhost:5173

# ----------------------------------------------------------------------------
# Default Postgres (used by existing admin/USSD platform — DO NOT remove)
# ----------------------------------------------------------------------------
# [REQ in non-test] direct connection to Postgres (default TypeORM connection)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=rim_db_dev

# ----------------------------------------------------------------------------
# JWT
# ----------------------------------------------------------------------------
# [REQ] min 32 chars
JWT_SECRET=replace-me-with-32-plus-character-random-string
JWT_EXPIRATION=12h
# [REQ] min 32 chars; must differ from JWT_SECRET
JWT_REFRESH_SECRET=replace-me-with-different-32-plus-character-string
JWT_REFRESH_EXPIRATION=7d

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
# [OPT] one of: REDIS_URL (production) OR REDIS_HOST/REDIS_PORT (development)
# REDIS_URL=redis://default:password@host:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
# [OPT] default cache TTL in seconds
REDIS_TTL=3600

# ----------------------------------------------------------------------------
# Throttling (per-route limits, requests per TTL ms)
# ----------------------------------------------------------------------------
# [OPT] global default
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
# [OPT] login route (most aggressive)
THROTTLE_AUTH_LOGIN_TTL=60000
THROTTLE_AUTH_LOGIN_LIMIT=5
# [OPT] other auth routes
THROTTLE_AUTH_OTHER_TTL=60000
THROTTLE_AUTH_OTHER_LIMIT=10
# [OPT] admin routes
THROTTLE_ADMIN_TTL=60000
THROTTLE_ADMIN_LIMIT=100
# [OPT] per-API-key rate limit (Airtel-side ingest, USSD callers, MNO API)
# Raise these to stress-test or accommodate production telco volumes.
API_KEY_RATE_LIMIT=1000
API_KEY_RATE_TTL_SECONDS=60

# ----------------------------------------------------------------------------
# Email (Zeptomail / SMTP)
# ----------------------------------------------------------------------------
EMAIL_HOST=smtp.zeptomail.com
EMAIL_PORT=587
EMAIL_USER=emailapikey
# [REQ in non-test] SMTP password / API key
EMAIL_PASS=
EMAIL_FROM=noreply@rim.ng
EMAIL_FROM_NAME=RIM Team

# ----------------------------------------------------------------------------
# Swagger (production: protect with HTTP Basic)
# ----------------------------------------------------------------------------
# [OPT] if both set, Swagger is gated by HTTP Basic auth
SWAGGER_USERNAME=
SWAGGER_PASSWORD=

# ----------------------------------------------------------------------------
# Log signing
# ----------------------------------------------------------------------------
# [OPT] path for the signed log destination
LOG_FILE_PATH=./logs/app.log

# ============================================================================
# CSDP — Phase 1 (Airtel integration). All optional in dev; required in prod.
# ============================================================================

# ----------------------------------------------------------------------------
# Batch process (separate Nest bootstrap from src/main.batch.ts)
# ----------------------------------------------------------------------------
# [OPT] internal listen port for the batch container
BATCH_PORT=3000
# [OPT] set to '1' inside the batch process to enable BullMQ schedulers
# (already set by main.batch.ts; do not set this for the hot API process)
RUN_SCHEDULERS=

# ----------------------------------------------------------------------------
# CSDP TypeORM connections (PgBouncer-fronted)
# ----------------------------------------------------------------------------
# [OPT] DSN for the hot pool (NestJS API → PgBouncer transaction pool, size ~20)
# Falls back to DB_* if unset (dev convenience without PgBouncer).
DATABASE_HOT_URL=postgresql://postgres:postgres@pgbouncer:5432/rim_db_dev
# [OPT] DSN for the batch pool (workers → PgBouncer transaction pool, size ~3)
DATABASE_BATCH_URL=postgresql://postgres:postgres@pgbouncer:5432/rim_db_dev
# [OPT] DSN that bypasses PgBouncer (direct to Postgres) — used by migrations
# (CREATE INDEX CONCURRENTLY, partitioned-table DDL, etc. require session pooling)
DATABASE_DIRECT_URL=postgresql://postgres:postgres@postgres:5432/rim_db_dev

# Per-pool sizing (TypeORM `extra.max` — must match PgBouncer default_pool_size)
CSDP_HOT_POOL_MAX=20
CSDP_BATCH_POOL_MAX=3
CSDP_DB_IDLE_TIMEOUT_MS=10000

# Optional split-host overrides (rarely needed; URLs above are preferred)
# CSDP_HOT_DB_HOST=
# CSDP_HOT_DB_PORT=
# CSDP_HOT_DB_USERNAME=
# CSDP_HOT_DB_PASSWORD=
# CSDP_HOT_DB_NAME=
# CSDP_BATCH_DB_HOST=
# CSDP_BATCH_DB_PORT=
# CSDP_BATCH_DB_USERNAME=
# CSDP_BATCH_DB_PASSWORD=
# CSDP_BATCH_DB_NAME=

# ----------------------------------------------------------------------------
# CSDP API-key auth (Airtel-facing routes: /csdp/eligibility, /csdp/webhooks/*, /csdp/ingest/*)
# ----------------------------------------------------------------------------
# [REQ in production] shared secret Airtel sends in `x-csdp-api-key` header.
# In development, leave empty to bypass the check (guard logs a warning).
CSDP_API_KEY=
# [OPT] comma-separated scopes granted to that key. Defaults to all three.
# Until per-tenant DB-backed keys land, this is global.
CSDP_API_KEY_SCOPES=csdp:profile,csdp:webhook,csdp:ingest

# ----------------------------------------------------------------------------
# Teamwee adapter (eligibility upstream — flip DECISION_MODE flag to PROXY once configured)
# ----------------------------------------------------------------------------
# [REQ when DECISION_MODE=PROXY/SHADOW/LIVE_*] base URL of Teamwee API
TEAMWEE_BASE_URL=
# [REQ when DECISION_MODE=PROXY/SHADOW/LIVE_*] bearer token / API key
TEAMWEE_API_KEY=
# [OPT] hard timeout per Teamwee call in ms
TEAMWEE_TIMEOUT_MS=800
# [OPT] consecutive failures before circuit opens
TEAMWEE_CB_THRESHOLD=5
# [OPT] ms before half-open probe after circuit opens
TEAMWEE_CB_RESET_MS=30000

# ----------------------------------------------------------------------------
# CSDP ingest (daily file uploads from Airtel via /csdp/ingest/*)
# ----------------------------------------------------------------------------
# [OPT] directory where incoming uploads are streamed to disk (Multer dest)
CSDP_INGEST_TMP_DIR=/tmp/csdp-ingest-uploads
# [OPT] permanent storage root for parsed batch files
CSDP_INGEST_STORAGE_DIR=/tmp/csdp-ingest
# [OPT] max single-file size in bytes (default 1 GiB)
CSDP_INGEST_MAX_BYTES=1073741824

# ============================================================================
# Local-only overrides
# ============================================================================
# Add additional non-shared values to .env.local (auto-loaded by ConfigModule).
# Keep .env.local out of version control.
