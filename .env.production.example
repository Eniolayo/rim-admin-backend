# Template for /data/compose/.env on the production VM.
# Copy to /data/compose/.env, fill in real values, then chmod 600.
# Do NOT commit .env. Do NOT keep secrets inside the repo dir.

# --- App ---
API_PREFIX=api
# Comma-separated CORS origins. Empty is fine for server-to-server (Airtel).
ALLOWED_ORIGINS=
FRONTEND_URL=

# --- Postgres ---
DB_USERNAME=
DB_PASSWORD=
DB_NAME=rim_db

# --- Redis ---
REDIS_PASSWORD=

# --- JWT (min 32 chars; secret and refresh secret MUST differ) ---
JWT_SECRET=
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRATION=7d

# --- Email (ZeptoMail) ---
# Rotate the previous key — it was committed in the old docker-compose.yml.
EMAIL_HOST=smtp.zeptomail.com
EMAIL_PORT=587
EMAIL_USER=emailapikey
EMAIL_PASS=
EMAIL_FROM=noreply@rim.ng
EMAIL_FROM_NAME=RIM Team

# --- CSDP / Airtel API auth ---
# Shared secret Airtel sends in the `x-csdp-api-key` header on every CSDP route.
# Generate with: openssl rand -hex 32
CSDP_API_KEY=
CSDP_API_KEY_SCOPES=csdp:profile,csdp:webhook,csdp:ingest

# --- Teamwee (eligibility upstream) ---
# Leave empty until DECISION_MODE flips to PROXY/SHADOW/LIVE_*.
TEAMWEE_BASE_URL=
TEAMWEE_API_KEY=
